{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Sample JSON CloudFormation template with cost optimization opportunities",
  "Resources": {
    "LargeInstance": {
      "Type": "AWS::EC2::Instance",
      "Properties": {
        "InstanceType": "m5.8xlarge",
        "ImageId": "ami-0abcdef1234567890",
        "Tags": [
          { "Key": "Name", "Value": "oversized-instance" }
        ]
      }
    },
    "UnusedVolume": {
      "Type": "AWS::EC2::Volume",
      "Properties": {
        "AvailabilityZone": "us-east-1a",
        "Size": 200,
        "VolumeType": "io1",
        "Iops": 1000
      }
    },
    "SmallDB": {
      "Type": "AWS::RDS::DBInstance",
      "Properties": {
        "DBInstanceClass": "db.m5.4xlarge",
        "Engine": "postgres",
        "MasterUsername": "admin",
        "MasterUserPassword": "password123",
        "AllocatedStorage": 100,
        "StorageType": "gp2"
      }
    },
    "FloatingEIP": {
      "Type": "AWS::EC2::EIP",
      "Properties": {
        "Domain": "vpc"
      }
    }
  }
}
